{
  "name": "@tecp/di",
  "version": "1.1.5",
  "description": "A lightweight, zero-dependency Dependency Injection container for TypeScript.",
  "keywords": [
    "DI",
    "dependency injection",
    "dependency",
    "injection",
    "container",
    "typescript",
    "singleton",
    "transient"
  ],
  "author": "zhanjh <zhanjh@126.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/tecposter/tecp-di"
  },
  "license": "MIT",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.0.6",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "25.9.1",
    "tsx": "4.22.3",
    "typescript": "6.0.3"
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json",
    "test": "node --import tsx --test \"./**/*.test.ts\"",
    "prepublishOnly": "pnpm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./container": {
      "types": "./dist/container.d.ts",
      "import": "./dist/container.js",
      "default": "./dist/container.js"
    }
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js"
}
